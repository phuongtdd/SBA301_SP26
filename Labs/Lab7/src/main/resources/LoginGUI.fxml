<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="323.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sba301.lab7.controller.LoginController">
    <children>
        <Pane prefHeight="62.0" prefWidth="397.0" style="-fx-background-color: #2D75E8;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="-1.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="122.0" layoutY="8.0" text="LOGIN FORM" textFill="WHITE">
                    <font>
                        <Font size="26.0" />
                    </font>
                </Label>
            </children>
        </Pane>
        <GridPane layoutX="20.0" layoutY="100.0" prefHeight="185.0" prefWidth="420.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="429.0" minWidth="10.0" prefWidth="427.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="281.0" minWidth="10.0" prefWidth="148.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <HBox prefHeight="61.0" prefWidth="362.0">
                    <children>
                        <Label text="Email :" />
                        <TextField fx:id="txtEmail" prefHeight="31.0" prefWidth="254.0">
                            <HBox.margin>
                                <Insets left="35.0" />
                            </HBox.margin>
                        </TextField>
                    </children>
                </HBox>
                <HBox prefHeight="75.0" prefWidth="372.0" GridPane.rowIndex="1">
                    <children>
                        <Label text="Password :" />
                        <PasswordField fx:id="txtPassword" prefHeight="32.0" prefWidth="260.0">
                            <HBox.margin>
                                <Insets left="10.0" />
                            </HBox.margin>
                        </PasswordField>
                    </children>
                </HBox>
                <HBox maxWidth="-Infinity" prefHeight="77.0" prefWidth="210.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <HBox prefHeight="1.0" prefWidth="349.0" GridPane.rowIndex="2">
                    <children>
                        <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#login" prefHeight="33.0" prefWidth="77.0" text="Login">
                            <HBox.margin>
                                <Insets left="80.0" />
                            </HBox.margin>
                        </Button>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#hello" prefHeight="34.0" prefWidth="86.0" text="Cancel">
                            <HBox.margin>
                                <Insets left="50.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
                <HBox maxWidth="-Infinity" prefHeight="60.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>
    </children>
